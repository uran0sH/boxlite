{
  "swagger": "2.0",
  "info": {
    "title": "BoxLite Analytics API",
    "description": "BoxLite Analytics API - Read-only telemetry and usage data. Authenticated via BoxLite API keys or JWT tokens.",
    "version": "v0.0.0-dev"
  },
  "host": "localhost:8080",
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "paths": {
    "/organization/{organizationId}/box/{boxId}/usage": {
      "get": {
        "summary": "Get box usage periods",
        "description": "Retrieve usage periods for a specific box within a time range",
        "tags": ["Usage"],
        "produces": ["application/json"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "description": "Organization ID",
            "required": true,
            "type": "string"
          },
          {
            "name": "boxId",
            "in": "path",
            "description": "Box ID",
            "required": true,
            "type": "string"
          },
          {
            "name": "from",
            "in": "query",
            "description": "Start time (RFC3339)",
            "required": true,
            "type": "string"
          },
          {
            "name": "to",
            "in": "query",
            "description": "End time (RFC3339)",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/models.UsagePeriod" }
            }
          }
        }
      }
    },
